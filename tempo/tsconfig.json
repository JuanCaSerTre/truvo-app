{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "react-native": [
        "./node_modules/react-native"
      ],
      "react-native/*": [
        "./node_modules/react-native/*"
      ],
      "react-native-web": [
        "./node_modules/react-native-web"
      ],
      "react-native-web/*": [
        "./node_modules/react-native-web/*"
      ],
      "@/*": [
        "../src/*"
      ]
    }
  },
  "include": [
    "expo-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../src/**/*",
    "designs/canvases/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
